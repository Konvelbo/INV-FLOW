generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  name      String
  password  String
  avatar    String?
  invoices  Invoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Invoice {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  reference     String   @unique
  city          String


  clientName    String
  object        String
  clientAddress String?
  clientContact String?
  clientPOBox   String?
  managerName   String


  totalHT       Float
  totalMaterial Float
  amountWords   String?

  pdfUrl        String?
  pdfPublicId   String?   // Cloudinary

  userId       String @db.ObjectId
  author       User     @relation(fields: [userId], references: [id])

  @@index([userId])

  isScaled      Boolean @default(false)
  style         String  @default("default")
  createdAt     DateTime @default(now())

  items         InvoiceItem[]
}

model InvoiceItem {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  designation String
  unit        String @default("U")
  quantity    Float
  unitPrice   Float
  totalPrice  Float

  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id])
}
