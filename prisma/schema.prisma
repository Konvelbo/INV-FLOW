generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  name      String
  password  String
  avatar    String?
  invoices  Invoice[]
  todos     Todo[]
  pushSubscriptions PushSubscription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Todo {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  description String?
  completed   Boolean  @default(false)
  status      String   @default("todo") // todo, in_progress, done
  priority    String   @default("medium") // low, medium, high
  category    String   @default("work") // work, personal, study, sport, etc.
  
  startTime   DateTime?
  endTime     DateTime?
  reminderAt  DateTime?
  
  userId      String   @db.ObjectId
  user        User     @relation(fields: [userId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model Invoice {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  reference     String   @unique
  city          String


  clientName    String
  object        String
  clientAddress String?
  clientContact String?
  clientPOBox   String?
  managerName   String


  totalHT       Float
  totalMaterial Float
  amountWords   String?

  pdfUrl        String?
  pdfPublicId   String?   // Cloudinary

  userId       String @db.ObjectId
  author       User     @relation(fields: [userId], references: [id])

  @@index([userId])

  isScaled      Boolean @default(false)
  style         String  @default("default")
  createdAt     DateTime @default(now())

  items         InvoiceItem[]
}

model InvoiceItem {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  designation String
  unit        String @default("U")
  quantity    Float
  unitPrice   Float
  totalPrice  Float

  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id])
}

model PushSubscription {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  endpoint  String   @unique
  p256dh    String
  auth      String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@index([userId])
}
