{
  "name": "essor",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"next dev\" \"npm run electron:dev\"",
    "electron:dev": "wait-on http://localhost:3000 && cross-env NODE_ENV=development electron .",
    "electron:build": "wait-on http://localhost:3000 && cross-env NODE_ENV=production electron-builder --dir",
    "build": "next build",
    "start": "next start",
    "lint": "eslint"
  },
  "build": {
    "appId": "essor",
    "productName": "ESSOR",
    "compression": "maximum",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "installerIcon": "/logo-caracterer-bg-non-ESSOR.png",
      "uninstallerIcon": "/logo-caracterer-bg-non-ESSOR.png",
      "license": "licence.md",
      "perMachine": false,
      "allowToChangeInstallationDirectory": false
    }
  },
  "publish": {
    "provider": "github",
    "owner": "tonusername",
    "repo": "tonrepo"
  },
  "asar": true,
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.2.2",
    "@internationalized/date": "^3.11.0",
    "@prisma/client": "~6.19.2",
    "@remixicon/react": "^4.9.0",
    "@tabler/icons-react": "^3.38.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/pg": "^8.18.0",
    "@types/web-push": "^3.6.4",
    "axios": "^1.13.6",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "cloudinary": "^2.9.0",
    "clsx": "^2.1.1",
    "daisyui": "^5.5.19",
    "date-fns": "^4.1.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.576.0",
    "motion": "^12.34.4",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "openai": "^6.25.0",
    "pnpm": "^10.30.3",
    "prisma": "~6.19.2",
    "puppeteer": "^24.37.5",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-aria-components": "^1.15.1",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.2",
    "react-hot-toast": "^2.6.0",
    "recharts": "^3.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "uuid": "^13.0.0",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.6.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "wait-on": "^9.0.4"
  }
}
